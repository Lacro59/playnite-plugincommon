<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:enumerations="clr-namespace:CommonPluginsStores.Models.Enumerations">

    <Style x:Key="StoreAuthStatusBadge" TargetType="Border">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{DynamicResource PanelSeparatorBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource NormalBorderBrush}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Style.Triggers>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.Ok}">
                <Setter Property="BorderBrush" Value="{DynamicResource GlyphBrush}" />
                <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.AuthRequired}">
                <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.Failed}">
                <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.PrivateAccount}">
                <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StoreAuthStatusBadgeText" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Style.Triggers>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.Ok}">
                <Setter Property="Foreground" Value="{DynamicResource GlyphBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.AuthRequired}">
                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.Failed}">
                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.PrivateAccount}">
                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.Checking}">
                <Setter Property="Foreground" Value="{DynamicResource TextBrushDarker}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StoreNavAuthStatusDot" TargetType="Ellipse">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="8,0,4,0" />
        <Setter Property="Fill" Value="{DynamicResource TextBrushDarker}" />
        <Style.Triggers>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.Ok}">
                <Setter Property="Fill" Value="{DynamicResource GlyphBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.AuthRequired}">
                <Setter Property="Fill" Value="{DynamicResource WarningBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.Failed}">
                <Setter Property="Fill" Value="{DynamicResource WarningBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.PrivateAccount}">
                <Setter Property="Fill" Value="{DynamicResource WarningBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.Checking}">
                <Setter Property="Fill" Value="{DynamicResource TextBrushDarker}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StoreNavAuthStatusToolTipText" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Style.Triggers>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.Checking}">
                <Setter Property="Text" Value="{DynamicResource LOCCommonLoginChecking}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.Ok}">
                <Setter Property="Text" Value="{DynamicResource LOCCommonLoggedIn}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.AuthRequired}">
                <Setter Property="Text" Value="{DynamicResource LOCCommonNotLoggedIn}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.PrivateAccount}">
                <Setter Property="Text" Value="{DynamicResource LOCSteamRequiresApiKey}" />
            </Trigger>
            <Trigger Property="Tag" Value="{x:Static enumerations:AuthStatus.Failed}">
                <Setter Property="Text" Value="{DynamicResource LOCCommonNotLoggedInError}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StoreFormGrid" TargetType="Grid">
        <Setter Property="Margin" Value="0" />
    </Style>

</ResourceDictionary>
