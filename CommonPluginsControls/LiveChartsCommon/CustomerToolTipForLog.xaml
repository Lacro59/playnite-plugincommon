<UserControl x:Class="CommonPluginsControls.LiveChartsCommon.CustomerToolTipForLog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:wpf="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf" 
             xmlns:livechartscommon="clr-namespace:CommonPluginsControls.LiveChartsCommon"
             mc:Ignorable="d" d:DesignHeight="300" d:DesignWidth="300">

    <UserControl.Resources>
        <livechartscommon:DashArrayFromTitleConverter x:Key="DashConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <UserControl.Template>
        <ControlTemplate>
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="{DynamicResource CommonToolTipBackgroundBrush}" 
                        CornerRadius="{DynamicResource CommonToolTipCornerRadius}"
                        BorderThickness="{DynamicResource CommonToolTipBorderThickness}" 
                        Padding="{DynamicResource CommonToolTipPadding}"
                        BorderBrush="{DynamicResource CommonToolTipBorderBrush}">
                    <StackPanel>
                        <!-- Title (Time/Date) -->
                        <StackPanel Margin="0,0,0,10" Visibility="{Binding ShowTitle, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding DataTitle}" HorizontalAlignment="Center" FontWeight="Bold"
                                       FontSize="16" Style="{DynamicResource BaseTextBlockStyle}" />
                        </StackPanel>

                        <!-- Items (Series) -->
                        <ItemsControl ItemsSource="{Binding Data.Points}" Grid.IsSharedSizeScope="True">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type wpf:DataPointViewModel}">
                                    <Grid Margin="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Title" />
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" SharedSizeGroup="Value" />
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" Width="40" Height="14" VerticalAlignment="Center">
                                            <Line X1="0" Y1="7" X2="40" Y2="7" 
                                                  Stroke="{Binding Series.Stroke}" 
                                                  StrokeThickness="2"
                                                  StrokeDashArray="{Binding Series.Title, Converter={StaticResource DashConverter}}" />
                                            <Path Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  StrokeThickness="1" Stroke="{Binding Series.Stroke}" Fill="{Binding Series.Stroke}" 
                                                  Stretch="Fill" Data="{Binding Series.PointGeometry}" />
                                        </Grid>

                                        <!-- Series Title -->
                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding Series.Title}" 
                                                   Style="{DynamicResource BaseTextBlockStyle}"
                                                   FontSize="16" VerticalAlignment="Center" />

                                        <!-- Value -->
                                        <TextBlock Grid.Column="4" FontSize="16" HorizontalAlignment="Right"
                                                   Text="{Binding ChartPoint.Y, StringFormat={}{0:0.##}}" 
                                                   VerticalAlignment="Center" Style="{DynamicResource BaseTextBlockStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </ControlTemplate>
    </UserControl.Template>
</UserControl>