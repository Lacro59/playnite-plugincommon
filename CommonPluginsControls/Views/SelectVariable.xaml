<UserControl x:Class="CommonPluginsControls.Controls.SelectVariable"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CommonPluginsControls.Controls"
             mc:Ignorable="d" d:DataContext="{d:DesignInstance local:SelectVariable, IsDesignTimeCreatable=False}"
             Height="400" Width="800">

    <DockPanel Margin="10" LastChildFill="True">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{DynamicResource SectionHeaderText}"
                       Text="{DynamicResource LOCCommonVariablePlaceholder}" />
            <TextBlock Grid.Column="2" Style="{DynamicResource SectionHeaderText}"
                       Text="{DynamicResource LOCCommonVariableResult}" />
        </Grid>

        <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource NormalBorderBrush}"
                Margin="0,10,0,0" DockPanel.Dock="Bottom">
            <DockPanel KeyboardNavigation.TabNavigation="Local" LastChildFill="False" Margin="0,5">
                <Button TabIndex="1" Name="PART_BtClose" Content="{DynamicResource LOCCloseLabel}"
                        DockPanel.Dock="Right"
                        Style="{StaticResource BottomButton}" Click="PART_BtClose_Click" />

                <Button TabIndex="0" Name="PART_BtInsert" Content="{DynamicResource LOCCommonInsertVariable}"
                        DockPanel.Dock="Right" IsEnabled="False"
                        Style="{StaticResource BottomButton}" Click="PART_BtInsert_Click" />
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl Name="PART_Categories">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="True" Margin="0,0,0,6">
                            <Expander.Header>
                                <TextBlock Style="{DynamicResource SectionHeaderText}" Text="{Binding CategoryName}" />
                            </Expander.Header>

                            <ListBox ItemsSource="{Binding Variables}"
                                     SelectionChanged="CategoryListBox_SelectionChanged"
                                     MouseDoubleClick="CategoryListBox_MouseDoubleClick"
                                     BorderThickness="0"
                                     Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="1.5*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Style="{DynamicResource BaseTextBlockStyle}"
                                                       Text="{Binding Name}" />
                                            <TextBlock Grid.Column="2" Style="{DynamicResource BaseTextBlockStyle}"
                                                       Text="{Binding Value}" TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
